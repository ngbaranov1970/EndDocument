# Скопируй в .env и заполни реальными значениями

# Путь к SQLite-базе (в docker задаётся через compose, локально можно не менять)
db_name=enddocument.db

# JWT — секрет сгенерируй командой: openssl rand -hex 32
jwt_secret_key=change_me
jwt_algorithm=HS256
jwt_access_token_expire_minutes=30
jwt_refresh_token_expire_days=7
